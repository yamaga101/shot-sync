<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Linear gradient: teal top-left → green bottom-right。
         Material You の light/dark どちらでも foreground (白) が映える濃さに調整 -->
    <path android:pathData="M0,0 H108 V108 H0 Z">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt" name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="108" android:endY="108">
                <item android:offset="0.0" android:color="#1A8E94"/>
                <item android:offset="0.5" android:color="#2BB673"/>
                <item android:offset="1.0" android:color="#4CD3A5"/>
            </gradient>
        </aapt:attr>
    </path>
</vector>
