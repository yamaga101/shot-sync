<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Read screenshot images. Android 13+ uses READ_MEDIA_IMAGES; older fallback. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Android 13+ runtime permission for upload-result notifications. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Boot-time / package-replace bootstrap to re-schedule MediaStore trigger job. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- v0.3.0 廃止: 常時 FGS は Android 15/target=35 の dataSync 6h cap +
         BOOT_COMPLETED 起動制限と本質的に衝突するため削除。catch-up は
         JobScheduler.addTriggerContentUri + WorkManager で event-driven 化。
         FOREGROUND_SERVICE / FOREGROUND_SERVICE_DATA_SYNC 削除済。
         REQUEST_IGNORE_BATTERY_OPTIMIZATIONS は WorkManager / JobScheduler の
         deferral 抑制目的で継続使用。 -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:name=".ShotSyncApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ShotSync"
        tools:targetApi="33"
        xmlns:tools="http://schemas.android.com/tools">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.ShotSync">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- MediaStore content-URI trigger を OS が wake してくれる JobService。
             Android 7.0+ の official `ACTION_NEW_PICTURE` 置換経路。
             dataSync FGS と異なり 24h 6h cap・BOOT_COMPLETED 制限の対象外。 -->
        <service
            android:name=".job.MediaStoreTriggerJobService"
            android:permission="android.permission.BIND_JOB_SERVICE"
            android:exported="false" />

        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
